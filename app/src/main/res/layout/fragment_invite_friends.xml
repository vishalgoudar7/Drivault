        </LinearLayout>
        <!-- Invite Limit Layout -->

        <LinearLayout
            android:id="@+id/invite_limit_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="20dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:src="@drawable/ic_cloud_limit"
                android:layout_marginTop="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/invitation_limit_reached"
                android:textStyle="bold"
                android:textSize="28sp"
                android:textColor="@color/text_color"
                android:layout_marginTop="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/you_ve_invited_the_maximum_9_friends_nupgrade_storage_to_invite_more"
                android:textSize="16sp"
                android:textColor="#777777"
                android:gravity="center"
                android:layout_marginTop="10dp" />

            <!-- Basic Plan -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                app:cardCornerRadius="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/basic"
                        android:textColor="#0A7C3E"
                        android:textStyle="bold"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/_100_gb"
                        android:textStyle="bold"
                        android:textSize="34sp"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/_35_mo"
                        android:textStyle="bold"
                        android:textColor="#0A7C3E"
                        android:textSize="28sp"
                        android:layout_marginTop="10dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_upgrade"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="@string/get_discount"
                        android:textAllCaps="false"
                        android:textColor="#0A7C3E"
                        android:backgroundTint="#DDF3E5"
                        android:layout_marginTop="18dp"
                        app:cornerRadius="30dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Explore Button -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_explore"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="@string/explore_more_plans"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#0A7C3E"
                android:layout_marginTop="25dp"
                app:cornerRadius="30dp" />

        </LinearLayout>
        <LinearLayout
            android:id="@+id/invite_friends_list_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/standard_padding"
